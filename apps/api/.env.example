# ---------------------------------------------------------------------------
# urano-api — copy to apps/api/.env and replace CHANGE_ME values
# Never commit real secrets.
# ---------------------------------------------------------------------------

PORT=3000
NODE_ENV=development

# Postgres (app connection string)
DATABASE_URL=postgres://urano:CHANGE_ME@localhost:5432/urano_finbot

# Redis (include password when requirepass is set)
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Allowed browser origin for CORS
CORS_ORIGIN=http://localhost:8080

# Background job scheduler (set false on HTTP API when running `bun run worker:jobs` separately)
# SCHEDULER_ENABLED=true

# Rate limit store failure mode (Redis down):
# production default = true (fail-closed → 503)
# development default = false (fail-open)
# RATE_LIMIT_FAIL_CLOSED=true

# Request limits
# BODY_LIMIT_BYTES=262144
# REQUEST_TIMEOUT_MS=30000

# Postgres backup script (scripts/backup-postgres.sh / `bun run backup`)
# BACKUP_DIR=./backups

# Used by docker-compose.yml for postgres / redis containers
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# MCP only (apps/api MCP server — optional):
# URANO_API_URL=http://localhost:3000/v1
# URANO_API_KEY=
