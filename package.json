{
  "name": "urano",
  "version": "0.0.1",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "worker:sync": "bun run src/infra/workers/cvm-sync-worker.ts",
    "mcp": "bun run src/infra/mcp/server.ts",
    "key:create": "bun run scripts/create-api-key.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "dotenv": "16",
    "drizzle-orm": "^0.45.2",
    "fastify": "5",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "zod": "3"
  }
}
